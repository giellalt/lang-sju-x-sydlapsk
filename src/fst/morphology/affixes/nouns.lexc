!! Noun inflection
!  ---------------
!! Lindahl & Öhrling page XLIVff

LEXICON Cases
 +N+Sg+Nom:0   #     ;


LEXICON N_EVEN_E
+N+Sg+Nom: # ;
+N+Sg+Nom:a # ;
+N:e xv_oblique ;
+N:a xv_oblique ;
+N: PX ; !possessive suffixes


LEXICON nv
+N+Sg+Nom: # ;
+N: xv_oblique ;
+N: PX ; !possessive suffixes


LEXICON xv_oblique
+Sg+Gen:%>n # ;
+Sg+Acc:%>b # ;
+Sg+Ill:^EA%>i # ;
+Sg+Ela:%>st # ;
+Sg+Ine:%>sne # ;
+Sg+Ine:%>sn # ;
+Sg+Ine:%>n # ;
+Sg+Com:%>in # ;
+Sg+Abe:%>t # ;
+Sg+Abe:%>tak # ;
+Sg+Abe:%>taka # ;
+Sg+Ess:%>n # ;

+Pl+Nom:%>h # ;
+Pl+Gen:%>i # ;
+Pl+Acc:%>it # ;
+Pl+Ill:%>it # ;
+Pl+Ill:%>iti # ;
+Pl+Ill:%>ita # ;
+Pl+Ela:%>ist # ;
+Pl+Ine:%>isne # ;
+Pl+Ine:%>in # ;
+Pl+Com:%>i # ;
+Pl+Ess:%>in # ;



LEXICON nc
+N+Sg+Nom: # ;
+N:        xc_oblique ;
+N:e PX ; !possessive suffixes

LEXICON xc_oblique
+Sg+Gen:e%>n # ;
+Sg+Acc:e%>b # ;
+Sg+Ill:e%>i # ;
+Sg+Ela:e%>st # ;
+Sg+Ine:e%>sne # ;
+Sg+Ine:e%>n # ;
+Sg+Com:e%>in # ;
+Sg+Abe:a%>tta # ;
+Sg+Abe:e%>tta # ;
+Sg+Ess:e%>n # ;

+Pl+Nom:e%>h # ;
+Pl+Gen:e%>i # ;
+Pl+Acc:e%>it # ;
+Pl+Ill:e%>it # ;
+Pl+Ela:e%>ist # ;
+Pl+Ine:e%>isne # ;
+Pl+Ine:e%>in # ;
+Pl+Com:e%>i # ;
+Pl+Ess:e%>in # ;






!possessive suffixes
LEXICON PX
!+Sg+Nom+PxSg1:%>  # ;
!+Sg+Nom+PxSg2:%>  # ;
!+Sg+Nom+PxSg3:%>  # ;
