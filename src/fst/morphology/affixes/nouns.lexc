!+Sg+Acc+PxSg1:%>  # ;
+Sg+Acc+PxSg2:%>bt # ; !kiälebt
+Sg+Acc+PxSg3:%>bs # ; !attjebs
!+Sg+Acc+PxDu1:%>  # ;
!+Sg+Acc+PxDu2:%>  # ;
